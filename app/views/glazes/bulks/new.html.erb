
<%= render 'breadcrumb', items: [
  [current_studio.name, studio_path(current_studio)],
  ['設定', studio_settings_path(current_studio)],
  ['釉薬', studio_glazes_path(current_studio)],
  '一括登録'
] %>

<%= bootstrap_form_with url: [current_studio, :glazes, :bulk] do |f| %>
  <%= f.textarea :names, label: '名前', required: true, class: 'auto-resize', help: safe_join(['改行を入れて複数個一括登録できます', '登録済みや入力が重複している名前はスキップされます'], tag.br) %>

  <%= f.primary '一括登録' %>
  <%= link_to 'キャンセル', studio_glazes_path(current_studio), class: 'btn btn-outline-primary' %>
<% end %>
