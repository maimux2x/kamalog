<h1>Welcome</h1>
<% unless authenticated? %>
  <div class="d-flex gap-3">
    <% unless Rails.env.production? %>
      <%= button_to 'Developer アカウントでログイン', '/auth/developer', class: 'btn btn-primary', data: {turbo: false} %>
    <% end %>

    <%= button_to 'Google アカウントでログイン', '/auth/google_oauth2', class: 'btn btn-primary', data: {turbo: false} %>
  </div>
<% end %>
