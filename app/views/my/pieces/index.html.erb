<%= render 'breadcrumb', items: [
  [current_studio.name, studio_path(current_studio)],
  '自分の作品'
] %>

<%= link_to '作品を登録', new_studio_my_piece_path(current_studio), class: 'btn btn-outline-primary mb-3' %>

<div class="grid">
  <% @pieces.each do |piece| %>
    <div
      class="g-col-6 card mb-3 d-grid row-gap-0"
      style="grid-row: span 2; grid-template-rows: subgrid;"
    >
      <div
        class="card-body d-grid"
        style="grid-row: span 2; grid-template-rows: subgrid;"
      >
        <h5 class="card-title">
          <%= link_to piece.title, studio_my_piece_path(current_studio, piece), class: 'stretched-link text-decoration-none' %>
        </h5>

        <div>
          <time datetime="<%= piece.created_at.iso8601 %>">
            <%= l piece.created_at.to_date %>
          </time>

          <span class="badge <%= status_badge_class(piece.status) %>">
            <%= piece.status_i18n %>
          </span>
        </div>
      </div>
    </div>
  <% end %>
</div>
