<h1 class="mb-3">制作する作品を登録</h1>

<div class="mb-3">
  <%= bootstrap_form_with model: [:my, @piece], method: :post do |f| %>
    <%= f.text_field :title, label: 'タイトル' %>
    <%= f.collection_radio_buttons :form_method, Piece.form_methods_i18n, :first, :last, label: '成形方法' %>

    <%= f.fields_for :clay_usages do |clay_usage_form| %>
      <div class="d-flex gap-3">
        <%= clay_usage_form.select :clay_id, Clay.all.map { [it.name, it.id] }, {include_blank: true, label: '土の種類'} %>
        <%= clay_usage_form.number_field :weight, label: '使用量' %>
      </div>
    <% end %>

    <%= f.primary %>
  <% end %>
</div>
<hr/>

<%= link_to 'キャンセル', my_in_progress_index_path, class: 'btn btn-outline-primary' %>
