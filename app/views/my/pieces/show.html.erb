<nav aria-label="breadcrumb">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><%= link_to 'ホーム', studio_path(current_studio) %></li>

    <li class="breadcrumb-item">
      <%= link_to '自分の作品一覧', studio_my_pieces_path(current_studio) %>
    </li>

    <li class="breadcrumb-item active" aria-current="page">
      <%= @piece.title %>
    </li>
  </ol>
</nav>

<%= render 'my/piece_tab', studio: current_studio, piece: @piece %>

<div class="card mb-3">
  <div class="card-body">
    <div class="grid mb-3">
      <% @piece.photos.each do |photo| %>
        <div
          class="g-col-12 g-col-md-6 d-grid row-gap-0 border"
          style="grid-row: span 2; grid-template-rows: subgrid;"
        >
          <div class="d-flex align-items-center bg-light">
            <%= link_to image_tag(photo.file, class: 'w-100', alt: ''), photo.file %>
          </div>

          <small class="p-2"><%= photo.caption %></small>
        </div>
      <% end %>
    </div>

    <dl>
      <% if @piece.description.present? %>
        <dt>作品説明</dt>
        <dd><%= @piece.description %></dd>
      <% end %>

      <dt>進捗</dt>

      <dd>
        <span class="badge <%= status_badge_class(@piece.status) %>">
          <%= @piece.status_i18n %>
        </span>
      </dd>

      <dt>成形方法</dt>

      <dd><%= @piece.form_method_i18n %></dd>

      <dt>使用した土</dt>

      <% @piece.clay_usages.order(:id).each do |usage| %>
        <dd><%= usage.clay.name %> <%= usage.weight %>g</dd>
      <% end %>

      <% if @piece.glazes.present? %>
        <dt>使用した釉薬</dt>
        <dd><%= @piece.glazes.order(:id).pluck(:name).join(' / ') %></dd>
      <% end %>
    </dl>
  </div>
</div>

<div class="d-flex">
  <%= link_to '作品を編集', edit_studio_my_piece_path(current_studio, @piece), class: 'btn btn-outline-primary me-2' %>
  <%= button_to '削除', studio_my_piece_path(current_studio, @piece), method: :delete, class: 'btn btn-danger', form: {data: {turbo_confirm: '本当に削除しますか？'}} %>
</div>

<hr>

<%= link_to '戻る', studio_my_pieces_path(current_studio), class: 'btn btn-outline-primary' %>
