<%= render 'my/piece_tab', piece: @piece %>

<div>
  <%= link_to '作業記録を登録する', new_my_piece_log_path(@piece), class: 'btn btn-outline-primary mb-3' %>
</div>

<% @piece.logs.each do |log| %>
  <div class="card mb-3">
    <div class="card-body">
      <h2>
        <%= link_to log.title, my_piece_log_path(@piece, log), class: 'text-decoration-none stretched-link' %>
      </h2>

      <time datetime="<%= log.date %>" class="d-block mb-3">
        <%= log.date %>
      </time>

      <% if log.body.present? %>
        <p><%= log.body %></p>
      <% end %>
    </div>
  </div>
<% end %>

<%= link_to '戻る', my_pieces_path, class: 'btn btn-outline-primary' %>
