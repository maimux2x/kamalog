<%= render 'breadcrumb', items: [
  [current_studio.name, studio_path(current_studio)],
  ['自分の作品', studio_my_pieces_path(current_studio)],
  [@log.piece.title, studio_my_piece_path(current_studio, @log.piece)],
  ['作業記録', studio_my_piece_logs_path(current_studio, @log.piece)],
  [@log.date, studio_my_piece_log_path(current_studio, @log.piece, @log)],
  '編集'
] %>

<%= render 'form', studio: current_studio, log: @log %>
