<h1><%= @log.title %></h1>
<time datetime="<%= @log.date %>" class="d-block mb-3"><%= @log.date %></time>

<div class="card mb-3">
  <div class="card-body">
    <dl>
      <dt>作業内容</dt>
      <dd><%= @log.body %></dd>

      <dt>ギャラリー</dt>

      <dd>
        <% @log.photos.each do |photo| %>
          <%= image_tag photo.file.variant(:small), alt: '' %>
        <% end %>
      </dd>
    </dl>
  </div>
</div>

<div class="d-flex">
  <%= link_to '編集', edit_my_piece_log_path(@log.piece, @log), class: 'btn btn-primary me-2' %>
  <%= button_to '削除', my_piece_log_path(@log.piece, @log), method: :delete, data: {turbo_confirm: '本当に削除しますか？'}, class: 'btn btn-outline-danger' %>
</div>

<hr>
<%= link_to '戻る', my_piece_logs_path(@log.piece), class: 'btn btn-primary' %>
