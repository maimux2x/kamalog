<%= render 'breadcrumb', items: [
  [current_studio.name, studio_path(current_studio)],
  ['設定', studio_settings_path(current_studio)],
  ['土', studio_clays_path(current_studio)],
  '一括登録'
] %>

<%= bootstrap_form_with url: [current_studio, :clays, :bulk] do |f| %>
  <%= f.text_area :names, label: '名前', class: 'auto-resize', help: safe_join(['改行を入れて複数個一括登録できます', '登録済みや入力が重複している名前はスキップされます'], tag.br), required: true %>
  <%= f.primary %>
  <%= link_to 'キャンセル', studio_clays_path(current_studio), class: 'btn btn-outline-primary' %>
<% end %>
